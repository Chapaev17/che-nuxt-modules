{
  "name": "che-nuxt-modules",
  "version": "0.1.1",
  "license": "MIT",
  "packageManager": "yarn@4.10.3",
  "scripts": {
    "build": "vite build",
    "lint": "yarn lint:js && yarn lint:style",
    "lint:js": "eslint --ext .vue,.ts,.tsx,.js,.jsx  . && vue-tsc",
    "lint:style": "stylelint \"**/*{vue,css,scss,jsx,tsx}\"",
    "test": "yarn playwright test"
  },
  "lint-staged": {
    "*.{vue,ts,tsx,js,jsx}": "yarn lint:js",
    "*.{vue,css,scss,jsx,tsx}": "yarn lint:style",
    "*.{vue,ts,tsx,js,jsx,css,scss,md}": "prettier"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vueuse/components": "^14.2.0",
    "@vueuse/core": "^14.2.0",
    "animejs": "^4.3.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.27"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/che-nuxt-modules.umd.cjs",
  "module": "./dist/che-nuxt-modules.js",
  "exports": {
    ".": {
      "import": "./dist/che-nuxt-modules.js",
      "require": "./dist/che-nuxt-modules.umd.cjs"
    }
  }
}
