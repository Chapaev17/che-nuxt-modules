{
  "name": "@chapaev17/che-nuxt-modules",
  "description": "Vue composables and JSX components library",
  "version": "0.1.0",
  "license": "MIT",
  "keywords": [
    "vue"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "watch": "vite build --watch",
    "lint": "yarn eslint"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "lint-staged": {
    "*.{vue,ts,tsx,js,jsx}": "yarn lint:js",
    "*.{vue,css,scss,jsx,tsx}": "yarn lint:style",
    "*.{vue,ts,tsx,js,jsx,css,scss,md}": "prettier"
  },
  "devDependencies": {
    "@chapev17/eslint-config": "link:../eslint-config",
    "@types/node": "^25.2.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vueuse/components": "^14.2.0",
    "@vueuse/core": "^14.2.0",
    "animejs": "^4.3.5",
    "eslint": "^9.39.2",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.27"
  },
  "packageManager": "yarn@4.10.3"
}
